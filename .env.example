# -----------------------------------------------------------------------------
# WinKey - Environment Configuration Example
# -----------------------------------------------------------------------------
# LƯU Ý: Hiện tại dự án đã được tích hợp bộ Mock Auth tự động bỏ qua cổng Clerk.
# Bạn KHÔNG CẦN thiết lập các khóa API này để chạy hoặc build dự án ở chế độ local.
# -----------------------------------------------------------------------------

# Clerk Authentication Settings (Chỉ cần khi kích hoạt lại Clerk thực tế)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
# CLERK_SECRET_KEY=your_clerk_secret_key

# Clerk Redirect Paths (Đường dẫn chuyển hướng mặc định của Clerk)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up

# Application URLs
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
